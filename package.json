{
	"name": "aegis",
	"version": "0.1.0",
	"description": "Multi-tenant authorization gateway — enforcement boundary first",
	"main": "dist/server.js",
	"type": "module",
	"engines": {
		"node": ">=20.0.0",
		"pnpm": ">=10.0.0",
		"npm": "please-use-pnpm",
		"yarn": "please-use-pnpm"
	},
	"scripts": {
		"dev": "tsx watch src/server.ts",
		"build": "tsc --project tsconfig.build.json",
		"start": "node dist/server.js",
		"lint": "eslint src tests --ext .ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"migrate:up": "node-pg-migrate up --config-file database.json",
		"migrate:down": "node-pg-migrate down --config-file database.json",
		"migrate:create": "node-pg-migrate create --config-file database.json"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"packageManager": "pnpm@10.30.3",
	"dependencies": {
		"fastify": "^4.26.2",
		"@fastify/sensible": "^5.5.0",
		"postgres": "^3.4.4",
		"ioredis": "^5.3.2",
		"jsonwebtoken": "^9.0.2",
		"zod": "^3.22.4"
	},
	"devDependencies": {
		"@types/jsonwebtoken": "^9.0.6",
		"@types/node": "^20.12.7",
		"@typescript-eslint/eslint-plugin": "^7.8.0",
		"@typescript-eslint/parser": "^7.8.0",
		"eslint": "^8.57.0",
		"eslint-plugin-import": "^2.29.1",
		"node-pg-migrate": "^7.3.2",
		"tsx": "^4.8.2",
		"typescript": "^5.4.5",
		"vitest": "^1.5.3",
		"pg": "^8.11.5"
	}
}
